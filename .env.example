# Fitness Landing - Environment Variables
# Copy this file to .env.local and fill in actual values

# Application
REACT_APP_NAME=FitPulse
REACT_APP_DESCRIPTION=Professional Fitness Training & Wellness Programs

# Contact Information
REACT_APP_CONTACT_EMAIL=info@fitpulse.com
REACT_APP_CONTACT_PHONE=+1-555-FITNESS
REACT_APP_CONTACT_ADDRESS=456 Gym Street, Fitness City, FC 12345

# Business Hours (JSON format)
REACT_APP_OPENING_HOURS={"monday":"5:00-22:00","tuesday":"5:00-22:00","wednesday":"5:00-22:00","thursday":"5:00-22:00","friday":"5:00-22:00","saturday":"7:00-20:00","sunday":"8:00-18:00"}

# Social Media
REACT_APP_FACEBOOK_URL=https://facebook.com/fitpulse
REACT_APP_INSTAGRAM_URL=https://instagram.com/fitpulse
REACT_APP_TWITTER_URL=https://twitter.com/fitpulse
REACT_APP_YOUTUBE_URL=https://youtube.com/@fitpulse

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
REACT_APP_FACEBOOK_PIXEL_ID=123456789

# Forms & Submissions
REACT_APP_FORMSPREE_ID=formspree_id_here
REACT_APP_FORMSPREE_ENDPOINT=https://formspree.io/f/formspree_id_here

# Membership & Payments
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_your_stripe_key
REACT_APP_MEMBERSHIP_API_URL=https://api.fitpulse.com/v1/memberships

# API
REACT_APP_API_URL=https://api.fitpulse.com/v1
REACT_APP_API_TIMEOUT=10000

# Maps
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
REACT_APP_MAP_CENTER_LAT=40.7128
REACT_APP_MAP_CENTER_LNG=-74.0060

# Class Booking
REACT_APP_CLASS_BOOKING_API=https://api.fitpulse.com/v1/classes
REACT_APP_TRAINER_BOOKING_API=https://api.fitpulse.com/v1/trainers

# Sentry Error Tracking (optional)
REACT_APP_SENTRY_DSN=

# Environment
NODE_ENV=development